{
  "private": true,
  "name": "flag-blitz",
  "version": "0.1.0",
  "license": "BSD-3-Clause",
  "type": "module",
  "scripts": {
    "build": "npm run download-flags && node scripts/verify-flags.mjs && vite build",
    "deploy": "npm run type-check && npm run upload",
    "dev": "npm run download-flags && npm run build && devvit playtest",
    "download-flags": "node scripts/download-flags.mjs",
    "login": "devvit login",
    "type-check": "tsc --build",
    "upload": "npm run build && devvit upload"
  },
  "engines": {
    "node": ">=22.2.0"
  },
  "dependencies": {
    "@devvit/start": "0.13.7",
    "@devvit/web": "0.13.7",
    "@fontsource/inter": "^5.2.8",
    "@fontsource/montserrat": "^5.2.8",
    "@hono/node-server": "2.0.8",
    "devvit": "0.13.7",
    "hono": "4.12.28",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@tailwindcss/vite": "4.3.2",
    "@types/node": "^22.19.19",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "tailwindcss": "4.3.2",
    "typescript": "^5.8.3",
    "vite": "8.1.3"
  }
}
